---
import '../styles/reset.css';
import '../styles/global.css';
import Testimonials from '../components/Testimonials.astro';

const faqs = [
  {
    question: "Qui peut bénéficier de l'accompagnement ?",
    answer: "CRÈME s'adresse à toutes les pâtissières. Que tu veuilles lancer ton activité de zéro ou que tu sois déjà lancée mais que ça stagne. Si tu veux vivre de ta pâtisserie, tu es au bon endroit.",
  },
  {
    question: "Le premier rdv est-il gratuit ?",
    answer: "Oui, complètement. Le premier appel est un échange gratuit de 30 minutes pour parler de ta situation et voir si CRÈME est fait pour toi. Sans pression, sans engagement.",
  },
  {
    question: "Est-ce que tu coach toutes tes clientes toi même ?",
    answer: "Oui, chaque cliente est accompagnée directement par moi. Pas d'assistante, pas de délégation — tu as affaire à Sorenza du début à la fin.",
  },
  {
    question: "L'accompagnement dure combien de temps ?",
    answer: "L'accompagnement se déroule sur 3 mois. Et une fois terminé, tu gardes à vie l'accès à la communauté et au live hebdomadaire — parce que le chemin ne s'arrête pas à la fin des 3 mois.",
  },
  {
    question: "Puis-je me faire accompagner si je n'ai pas encore créer mon entreprise ?",
    answer: "Tout à fait. On peut même commencer par là. Structurer ton activité dès le départ, c'est justement ce qui t'évite de perdre du temps et de l'énergie plus tard.",
  },
  {
    question: "Partage tu des ressources ? Des cours, des vidéos ?",
    answer: "Oui. En plus de l'accompagnement, tu as accès à des ressources concrètes pour avancer entre nos sessions. Cours, vidéos, outils. Tout ce dont tu as besoin pour progresser à ton rythme.",
  },
];
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap" rel="stylesheet">
		<title>Offre Crème - Sorenza Patisserie</title>
	</head>
	<body>
		<main>
			<section class="section_hero">
				<div class="section_hero-container">
					<img src="/creme-logo1.png" alt="Logo Crème" class="logo_img" />
					<h1>OFFRE CRÈME</h1>
					<p class="hero_title">Fais <strong><em>décoller ton activité</em></strong>  de pâtisserie avec un accompagnement personnalisé</p>
					<p class="promesse">De 0 à +2000€ en 3 mois, une stratégie approuvée !</p>
					<p class="urgence">3 places par mois seulement !</p>
		
					<div class="vsl">
						<iframe
							src="https://www.youtube.com/embed/4-bpADHZ34U"
							style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
							frameborder="0"
							allowfullscreen>
						</iframe>
					</div>
		
					<a href="#contact" class="cta">
						<p>JE RÉSERVE MON <br> APPEL DÉCOUVERTE</p>
						<p class="cta_span">(PLACES LIMITÉES)</p>
					</a>
				</div>
			</section>

			<section class="section_pour-toi">
				<h2>Crème est fait pour toi si :</h2>
				<ul>
					<li>Tu es pâtissière de métier (ou passionnée) et tu veux enfin transformer ton savoir-faire en activité qui te paie vraiment</li>
					<li>Tu vends déjà de temps en temps, mais les commandes ne sont pas régulières, et cette instabilité t'épuise</li>
					<li>Tu ne sais pas quoi facturer, et tu as souvent l'impression de brader ton travail</li>
					<li>Tu as peur du regard des autres, ta famille qui doute, les gens sur les réseaux, les pros qui jugent</li>
					<li>Tu veux bosser depuis chez toi, sans boutique ni local, et sans dépendre d'un patron</li>
					<li>Tu es prête à travailler sérieusement, mais tu as besoin d'une méthode claire et de quelqu'un pour t'accompagner pas à pas</li>
				</ul>

			</section>

			<section class="section_pour-toi-cta">
				<p>Tu te reconnais ?</p>
				<p>Alors <span class="span-creme">CRÈME</span> est fait pour toi</p>
				<a href="#contact" class="cta">
					<p>JE PRENDS RDV</p>
					<p class="cta_span">(PLACES LIMITÉES)</p>
				</a>
			</section>

			<section class="section_changement">
				<h2>3 choses qui vont TOUT changer pour toi :</h2>
				<div>
					<img src="" alt="" />
					<p>Je vais <strong>écouter</strong> ta situation, <strong>identifier ce qui bloque</strong> ton activité et <strong>définir ensemble les objectifs</strong> qu'on va atteindre pas à pas.</p>
				</div>
				<div>
					<img src="" alt="" />
					<p>Je vais t'aider à <strong>éviter les erreurs</strong> qui te font perdre du temps et de l'argent pour que tu te concentres uniquement sur <strong>ce qui fonctionne vraiment.</strong></p>
				</div>
				<div>
					<img src="" alt="" />
					<p>Je vais te <strong>construire un plan d'action concret</strong> pour que tu <strong>stabilises ton chiffre d'affaires</strong> et que tu vives enfin pleinement de ta pâtisserie.</p>
				</div>
			</section>

			<section class="section_resultat">
				<h2>Les résultats que tu pourrais viser avec CRÈME :</h2>
				<div>
					<article>
						<img src="https://placehold.co/200x200" alt="" />
						<h3>+2000€ de CA mensuel en 2 mois</h3>
						<p>Clémence, @clemp_patisserie, pâtissière créatrice de macarons</p>
					</article>
					<article>
						<img src="https://placehold.co/200x200" alt="" />
						<h3>+750€ de CA en 10 jours</h3>
						<p>Léa, @vanileapatisserie, pâtisserie naturelles et créatives</p>
					</article>
					<article>
						<img src="https://placehold.co/200x200" alt="" />
						<h3>De 295 à 1490€ en 1 mois</h3>
						<p>Manon, @eclat_demanon, pâtisserie fine et pochage</p>
					</article>
				</div>
			</section>

			<Testimonials />

			<section class="faq" id="faq" aria-labelledby="faq-title">
				<div class="container">
					<h2 id="faq-title">F.A.Q.</h2>

					<dl class="faq__list reveal">
					{faqs.map((faq, i) => (
						<div class={`faq__item reveal reveal-delay-${(i % 3) + 1}`}>
						<details class="faq__details">
							<summary class="faq__question" aria-expanded="false">
							<span>{faq.question}</span>
							<span class="faq__icon" aria-hidden="true">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M6 9l6 6 6-6"/>
								</svg>
							</span>
							</summary>
							<dd class="faq__answer">
							<p>{faq.answer}</p>
							</dd>
						</details>
						</div>
					))}
					</dl>
				</div>
			</section>

			<section class="section_calendly" aria-labelledby="faq-title" id="contact">
				<div class="container">
					<h2>Réserve un créneau, discutons de ton projet</h2>

					<div class="calendly">
						<p style="text-align: center; font-style: italic; margin-top: 1rem;">Calendly</p>
					</div>
				</div>
			</section>

			<footer class="footer">
				&copy; 2026 Sorenza Pâtisserie - Tous droits réservés
			</footer>
		</main>
	</body>
</html>
