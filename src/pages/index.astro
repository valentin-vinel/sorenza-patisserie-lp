---
import '../styles/reset.css';
import '../styles/global.css';
import Testimonials from '../components/Testimonials.astro';

const faqs = [
  {
    question: "Qui peut bénéficier de l'accompagnement ?",
    answer: "CRÈME s'adresse à toutes les pâtissières. Que tu veuilles lancer ton activité de zéro ou que tu sois déjà lancée mais que ça stagne. Si tu veux vivre de ta pâtisserie, tu es au bon endroit.",
  },
  {
    question: "Le premier rdv est-il gratuit ?",
    answer: "Oui, complètement. Le premier appel est un échange gratuit pour parler de ta situation et voir si CRÈME est fait pour toi. Sans pression, sans engagement.",
  },
  {
    question: "Est ce que tu aide toutes tes clientes toi même ?",
    answer: "Oui, chaque cliente est accompagnée directement par moi. Pas d'assistante, pas de délégation.",
  },
  {
    question: "L'accompagnement dure combien de temps ?",
    answer: "L'accompagnement se déroule sur 3 mois. Et une fois terminé, tu gardes à vie  l'accès a ma plateforme avec tout les cours, les vidéo, ressources.",
  },
  {
    question: "Puis-je me faire accompagner si je n'ai pas encore créer mon entreprise ?",
    answer: "Tout à fait. On peut même commencer par là. Structurer ton activité dès le départ, c'est justement ce qui t'évite de perdre du temps et de l'énergie plus tard.",
  },
  {
    question: "Partage tu des ressources ? Des cours, des vidéos ?",
    answer: "Oui. Tu as accès à vie à la plateforme Skool avec plus de 80 vidéos et 15 cours. Tout ce que j'ai mis en place moi-même pour vendre mes pâtisseries tu y as accès en illimité, même après les 3 mois.",
  },
];
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap" rel="stylesheet">
		<title>Offre Crème - Sorenza Patisserie</title>
	</head>
	<body>
		<main>
			<section class="section_hero">
				<div class="section_hero-container">
					<img src="/creme-logo1.png" alt="Logo Crème" class="logo_img" />
					<h1>Accompagnement CRÈME</h1>
					<p class="hero_title">De <strong><em>0 à 2000€/mois depuis chez toi</em></strong>. <br> Sans boutique, sans patron, sans te brader.</p>
					<p class="promesse">La méthode d'une pâtissière qui a elle même vendu ses gâteaux</p>
					<p class="urgence">3 places par mois seulement !</p>
		
					<div class="vsl">
						<iframe
							src="https://www.youtube.com/embed/4-bpADHZ34U"
							style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
							frameborder="0"
							allowfullscreen>
						</iframe>
					</div>
		
					<a href="#contact" class="cta">
						<p>JE RÉSERVE MON <br> APPEL DÉCOUVERTE</p>
						<p class="cta_span">(PLACES LIMITÉES)</p>
					</a>
				</div>
			</section>

			<section class="section_pour-toi">
				<h2>Crème est fait pour toi si :</h2>
				<ul>
					<li>Tu es pâtissière de métier (ou passionnée) et tu veux enfin transformer ton savoir-faire en activité qui te paie vraiment</li>
					<li>Tu rêves de te lancer mais tu ne sais pas par où commencer et tu as peur de te planter</li>
					<li>Tu vends déjà de temps en temps, mais les commandes ne sont pas régulières, et cette instabilité t'épuise</li>
					<li>Tu ne sais pas comment fixer tes prix et tu as souvent l'impression de brader ton travail</li>
					<li>Tu as peur du regard des autres, ta famille qui doute, les gens sur les réseaux, ou qu'on dise que tu es trop cher</li>
					<li>Tu veux bosser depuis chez toi, sans boutique ni local, et sans dépendre d'un patron</li>
					<li>Tu es prête à travailler sérieusement, mais tu as besoin d'une méthode claire et de quelqu'un pour t'accompagner pas à pas</li>
				</ul>

			</section>

			<section class="section_pour-toi-cta">
				<p>Tu te reconnais ?</p>
				<p>Alors <span class="span-creme">CRÈME</span> est fait pour toi</p>
				<a href="#contact" class="cta">
					<p>JE RÉSERVE MON APPEL GRATUIT</p>
					<p class="cta_span">(PLACES LIMITÉES)</p>
				</a>
			</section>

			<section class="section_changement">
				<h2>3 choses qui vont TOUT changer pour toi :</h2>
				<div>
					<p>Tu sais enfin <strong>pourquoi ça bloque</strong> et tu as <strong>un plan clair pour avancer</strong>, plus de dispersion, plus de doutes sur quoi faire en premier</p>
				</div>
				<div>
					<p>Tu <strong>gagnes des mois en évitant les erreurs</strong> que j'ai mises un an à identifier (prix mal fixer, contenu qui ne vend pas, clients qui ne reviennent pas)</p>
				</div>
				<div>
					<p>Tu <strong>stabilises un chiffre d'affaires régulier</strong> depuis chez toi, et tu vend enfin pleinement de tes pâtisserie</p>
				</div>
			</section>

			<section class="section_resultat">
				<h2>Les résultats que tu pourrais viser avec CRÈME :</h2>
				<div>
					<article>
						<img src="/clemp-photo.jpg" alt="Logo clemp_patisserie" />
						<h3>Clémence de 0 à +2500€</h3>
						<p>Uniquement avec des macaron et dans un village </p>
					</article>
					<article>
						<img src="/eclat-photo.jpg" alt="Logo eclat_demanon" />
						<h3>Manon à stabilisé son CA à un minimum de 2000€</h3>
						<p>1500€ à Pâques en un week-end </p>
						<p>Spécialisé dans la pâtisserie fine</p>
					</article>
					<article>
						<img src="https://placehold.co/200x200" alt="" />
						<h3>Victoria de 0 à 1830$ en 3 mois</h3>
						<p>Avec des cakes design à Montréal</p>
					</article>
				</div>
			</section>

			<Testimonials />

			<section class="faq" id="faq" aria-labelledby="faq-title">
				<div class="container">
					<h2 id="faq-title">F.A.Q.</h2>

					<dl class="faq__list reveal">
					{faqs.map((faq, i) => (
						<div class={`faq__item reveal reveal-delay-${(i % 3) + 1}`}>
						<details class="faq__details">
							<summary class="faq__question" aria-expanded="false">
							<span>{faq.question}</span>
							<span class="faq__icon" aria-hidden="true">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M6 9l6 6 6-6"/>
								</svg>
							</span>
							</summary>
							<dd class="faq__answer">
							<p>{faq.answer}</p>
							</dd>
						</details>
						</div>
					))}
					</dl>
				</div>
			</section>

			<section class="section_calendly" aria-labelledby="faq-title" id="contact">
				<div class="container">
					<h2>Réserve un créneau, discutons de ton projet</h2>
					<!-- Début de widget en ligne Calendly -->
					<div class="calendly-inline-widget" data-url="https://calendly.com/sorenza-patisserie/appel-offert" style="min-width:320px;height:700px;"></div>
					<script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
					<!-- Fin de widget en ligne Calendly -->
				</div>

			</section>

			<footer class="footer">
				&copy; 2026 Sorenza Pâtisserie - Tous droits réservés
			</footer>
		</main>
	</body>
</html>
