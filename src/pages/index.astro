---
import '../styles/reset.css';
import '../styles/global.css';

const faqs = [
  {
    question: "Qui peut bénéficier de l'accompagnement ?",
    answer: "Lorem ipsum",
  },
  {
    question: "Le premier rdv est-il gratuit ?",
    answer: "Lorem ipsum",
  },
  {
    question: "Est-ce que tu coach toutes tes clientes toi même ?",
    answer: "Lorem ipsum",
  },
  {
    question: "L'accompagnement dure combien de temps ?",
    answer: "Lorem ipsum",
  },
  {
    question: "Puis-je me faire accompagner si je n'ai pas encore créer mon entreprise ?",
    answer: "Lorem ipsum",
  },
  {
    question: "Partage tu des ressources ? Des cours, des vidéos ?",
    answer: "Lorem ipsum",
  },
];
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="/reset.css">
		<link rel="stylesheet" href="/global.css">
		<title>Offre Crème - Sorenza Patisserie</title>
	</head>
	<body>
		<main>
			<section class="section_hero">
				<img src="/creme-logo1.png" alt="Logo Crème" class="logo_img" />
				<h1>OFFRE CRÈME</h1>
				<p>Fais décoller ton activité de pâtisserie avec un accompagnement personnalisé</p>
				<p class="promesse">De 0 à +2000€ en 3 mois, une stratégie approuvée !</p>
				<p class="urgence">3 places par mois seulement !</p>
	
				<div class="vsl">
					<iframe
						src="https://www.youtube.com/embed/MBCyczpIn74"
						style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
						frameborder="0"
						allowfullscreen>
					</iframe>
				</div>
	
				<a href="#contact" class="cta">
					<p>JE RÉSERVE MON <br> APPEL DÉCOUVERTE</p>
					<p class="cta_span">(PLACES LIMITÉES)</p>
				</a>
			</section>

			<section class="section_pour-toi">
				<h2>Crème est fait pour toi si :</h2>
				<ul>
					<li>Lorem ipsum dolor sit amet consectetur, adipisicing elit. Vero officiis fugiat libero mollitia dicta, ut dolorum earum tenetur reprehenderit vel distinctio fugit</li>
					<li>Lorem ipsum dolor sit, amet consectetur adipisicing elit. Exercitationem fugit nobis odio, autem minima nam dolor sequi?</li>
					<li>Lorem ipsum dolor sit amet consectetur adipisicing elit. Perferendis quia magni minima reprehenderit debitis placeat vel deserunt</li>
					<li>Lorem ipsum dolor, sit amet consectetur adipisicing elit. Voluptatem quisquam quis </li>
					<li>Lorem ipsum dolor sit amet consectetur adipisicing elit. Numquam, vitae rerum facilis quibusdam debitis optio doloremque distinctio. Doloremque officia accusamus</li>
					<li>Lorem ipsum dolor, sit amet consectetur adipisicing elit. Maiores minima repellendus ipsam inventore voluptas quaerat at in!</li>
				</ul>

			</section>

			<section class="section_pour-toi-cta">
				<p>Tu te reconnais ?</p>
				<p>Alors <span class="span-creme">CRÈME</span> est fait pour toi</p>
				<a href="#contact" class="cta">JE PRENDS RDV</a>
			</section>

			<section class="section_changement">
				<h2>3 choses qui vont TOUT changer pour toi :</h2>
				<div>
					<img src="" alt="" />
					<p>Lorem ipsum dolor, sit amet consectetur adipisicing elit. Reiciendis quasi fugiat explicabo voluptates omnis maxime</p>
				</div>
				<div>
					<img src="" alt="" />
					<p>Lorem ipsum dolor, sit amet consectetur adipisicing elit. Reiciendis quasi fugiat explicabo voluptates omnis maxime</p>
				</div>
				<div>
					<img src="" alt="" />
					<p>Lorem ipsum dolor, sit amet consectetur adipisicing elit. Reiciendis quasi fugiat explicabo voluptates omnis maxime</p>
				</div>
			</section>

			<section class="section_resultat">
				<h2>Les résultats que tu pourrais viser avec CRÈME :</h2>
				<div class="section_div">
					<article>
						<img src="https://placehold.co/200x200" alt="" />
						<h3>+2000€ de CA mensuel en 2 mois</h3>
						<p>Clémence, @clemp_patisserie, pâtissière créatrice de macarons</p>
					</article>
					<article>
						<img src="https://placehold.co/200x200" alt="" />
						<h3>+750€ de CA en 10 jours</h3>
						<p>Léa, @vanileapatisserie, pâtisserie naturelles et créatives</p>
					</article>
					<article>
						<img src="https://placehold.co/200x200" alt="" />
						<h3>De 295 à 1490€ en 1 mois</h3>
						<p>Manon, @eclat_demanon, pâtisserie fine et pochage</p>
					</article>
				</div>
			</section>

			<section class="section_temoignage">
				<h2>Mes clientes parlent de CRÈME :</h2>
				<article class="temoignage_card">
					<div class="temoignage_card-title">
						<img src="https://placehold.co/40x40" alt="Photo cliente" />
						<h3>Clémence</h3>
					</div>
					<p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Corrupti molestiae tenetur itaque incidunt distinctio, quae cum vero aliquid, doloribus iste iure maiores libero minus nesciunt.</p>
				</article>
				<article class="temoignage_card">
					<div class="temoignage_card-title">
						<img src="https://placehold.co/40x40" alt="Photo cliente" />
						<h3>Léa</h3>
					</div>
					<p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Corrupti molestiae tenetur itaque incidunt distinctio, quae cum vero aliquid, doloribus iste iure maiores libero minus nesciunt.</p>
				</article>
				<article class="temoignage_card">
					<div class="temoignage_card-title">
						<img src="https://placehold.co/40x40" alt="Photo cliente" />
						<h3>Aurore</h3>
					</div>
					<p>Lorem ipsum dolor sit amet consectetur adipisicing elit. Corrupti molestiae tenetur itaque incidunt distinctio, quae cum vero aliquid, doloribus iste iure maiores libero minus nesciunt.</p>
				</article>
			</section>

			<section class="faq" id="faq" aria-labelledby="faq-title">
				<div class="container">
					<h2 id="faq-title">F.A.Q.</h2>

					<dl class="faq__list reveal">
					{faqs.map((faq, i) => (
						<div class={`faq__item reveal reveal-delay-${(i % 3) + 1}`}>
						<details class="faq__details">
							<summary class="faq__question" aria-expanded="false">
							<span>{faq.question}</span>
							<span class="faq__icon" aria-hidden="true">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
								<path d="M6 9l6 6 6-6"/>
								</svg>
							</span>
							</summary>
							<dd class="faq__answer">
							<p>{faq.answer}</p>
							</dd>
						</details>
						</div>
					))}
					</dl>
				</div>
			</section>

			<section class="section_calendly" aria-labelledby="faq-title" id="contact">
				<div class="container">
					<h2 id="faq-title">Réserve un créneau, discutons de ton projet</h2>

					<div class="calendly">
						<p style="text-align: center; font-style: italic; margin-top: 1rem;">Calendly</p>
					</div>
				</div>
			</section>

			<footer class="footer">
				&copy; 2026 Sorenza Pâtisserie - Tous droits réservés
			</footer>
		</main>
	</body>
</html>
